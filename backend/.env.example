# Server
PORT=3000

# Database
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/library

# JWT
JWT_SECRET=change_me_to_a_strong_random_secret

# MinIO (S3-compatible object storage)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_UI_PORT=9001
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=library-books

# Elasticsearch
ELASTICSEARCH_URL=http://localhost:9200

# Admin registration secret (users who provide this key on register get the ADMIN role)
ADMIN_SECRET=change_me_to_a_strong_admin_secret
